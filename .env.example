# =============================================================================
# Kunuk — Configurazione d'ambiente (.env.example)
# =============================================================================
# Questo file è il TEMPLATE documentato e si committa nel repo.
# Copialo in `.env` e compila i valori reali:  cp .env.example .env
# Il file `.env` NON si committa MAI (è in .gitignore) e i segreti non entrano
# mai nelle immagini Docker: vengono iniettati a runtime (SR-17, doc 13).
# Ogni variabile nuova si aggiunge PRIMA qui (con commento), poi nel codice.
# Convenzione: prefisso KUNUK_, valori segreti marcati [SEGRETO].
# =============================================================================

# --- Applicazione --------------------------------------------------------
# Ambiente: dev | production
KUNUK_ENV=dev
# Indirizzo di ascolto dell'API Go (dietro Caddy, rete Docker frontend)
KUNUK_API_LISTEN_ADDR=:8080
# Base URL pubblica: usata per i link nelle email (MAI derivata dall'header
# Host — anti Host-header injection, doc 18 §1)
KUNUK_PUBLIC_BASE_URL=https://kunuk.example
# Livello di log: debug | info | warn | error (mai segreti nei log, doc 19 §5)
KUNUK_LOG_LEVEL=info

# --- Database (PostgreSQL, doc 07 + schema.sql) --------------------------
KUNUK_DB_HOST=postgres
KUNUK_DB_PORT=5432
KUNUK_DB_NAME=kunuk
# Ruolo applicativo a runtime: soggetto a RLS, niente DDL (SR-32)
KUNUK_DB_APP_USER=kunuk_app
KUNUK_DB_APP_PASSWORD=cambiami-app           # [SEGRETO]
# Ruolo migrazioni: usato SOLO al deploy/avvio per applicare le migrazioni
KUNUK_DB_MIGRATIONS_USER=kunuk_migrations
KUNUK_DB_MIGRATIONS_PASSWORD=cambiami-migr    # [SEGRETO]
# disable sulla rete Docker interna; require/verify-full se DB esterno
KUNUK_DB_SSLMODE=disable

# --- Bootstrap del container Postgres (solo Compose) ---------------------
# Superutente del CONTAINER: distinto dai ruoli applicativi qui sopra
POSTGRES_DB=kunuk
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambiami-super              # [SEGRETO]

# --- Sessioni (token opachi, SR-31) ---------------------------------------
# Durata della sessione (es. 12h, 30m)
KUNUK_SESSION_TTL=12h

# --- Recupero master password (ADR-0010, doc 05 §5) -----------------------
# Ritardo obbligatorio prima del completamento (168h = 7 giorni)
KUNUK_RECOVERY_DELAY_HOURS=168

# --- Email transazionali (SMTP UE, doc 07) --------------------------------
KUNUK_SMTP_HOST=smtp.provider-ue.example
KUNUK_SMTP_PORT=587
KUNUK_SMTP_USER=postmaster@kunuk.example
KUNUK_SMTP_PASSWORD=cambiami-smtp             # [SEGRETO]
# Mittente delle email (verifica account, notifiche recupero)
KUNUK_SMTP_FROM="Kunuk <no-reply@kunuk.example>"

# --- Notifiche Web Push / VAPID (ADR-0008) --------------------------------
# Genera la coppia una volta (es. `npx web-push generate-vapid-keys`)
KUNUK_VAPID_PUBLIC_KEY=
KUNUK_VAPID_PRIVATE_KEY=                      # [SEGRETO]
KUNUK_VAPID_SUBJECT=mailto:security@kunuk.example

# --- Rilevazione breach (doc 17 §6, SR-23) --------------------------------
# Endpoint range-query k-anonymity per le password (il client invia solo prefissi)
KUNUK_BREACH_RANGE_URL=https://api.pwnedpasswords.com/range
# Chiave del provider per il monitoraggio email (eccezione dichiarata, doc 02)
KUNUK_BREACH_EMAIL_API_KEY=                   # [SEGRETO]

# --- Aggiornamenti (modello Home Assistant, doc 07/08) --------------------
# Canale release: stable | beta
KUNUK_RELEASE_CHANNEL=stable
# Controllo aggiornamenti e notifica in-app (i self-hoster possono disattivare)
KUNUK_UPDATE_CHECK=true

# --- Ingress Caddy (scripts/infra/, ADR-0014) -----------------------------
# Dominio servito da Caddy (TLS automatico via ACME)
KUNUK_DOMAIN=kunuk.example
# Email per la registrazione ACME/Let's Encrypt
KUNUK_ACME_EMAIL=admin@kunuk.example

# --- Console amministrativa (ADR-0016) ------------------------------------
# Durata sessione admin (più corta di quella utente)
KUNUK_ADMIN_SESSION_TTL=1h
# Allowlist IP per la console (vuoto = nessuna restrizione; in produzione
# valutare anche mTLS a livello Caddy, doc 18 §3)
KUNUK_ADMIN_ALLOWED_IPS=
